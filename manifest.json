{
    "name": "個人情報非表示 in google.co.jp",
    "version": "1.1.0",
    "manifest_version": 3,
    "description": "google.co.jpの検索ページに存在する住所の表示を削除します。\nすべてのページで正しく動作する保証はありません。",
    "content_scripts": [
      {
        "matches": [
          "https://www.google.co.jp/*",
          "https://google.co.jp/*",
          "https://www.google.com/*",
          "https://google.com/*"
        ],
        "run_at": "document_start",
        "css": [
          "replace.css"
        ]
      }
      
    ]
  }